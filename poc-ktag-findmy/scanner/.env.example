# URL do backend 21 GO (sem /api/v1, o scanner adiciona)
# Local:    http://localhost:3001
# Produção: https://api.trackgo.site
API_BASE_URL=http://localhost:3001

# JWT do operador OU service account (gerar via login)
# curl -X POST http://localhost:3001/api/v1/auth/login \
#      -H "Content-Type: application/json" \
#      -d '{"email":"admin@rastreamento21go.com.br","password":"admin123"}'
# Pega o campo "token" da resposta.
JWT_TOKEN=

# Coordenadas onde o scanner está rodando (sua casa/escritório).
# Vai aparecer como "última posição conhecida" da TAG no mapa.
SCANNER_LAT=-23.55052
SCANNER_LNG=-46.633308

# Identificador free-form do scanner (aparece no histórico)
SCANNER_SOURCE=pc-juliano

# Mínimo de segundos entre posts da MESMA TAG (anti-spam)
MIN_INTERVAL_SECONDS=30

# Por quantos segundos escanear (0 = infinito)
SCAN_DURATION_SECONDS=0
