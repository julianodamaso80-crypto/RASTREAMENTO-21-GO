generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  SUPER_ADMIN
  ADMIN
  OPERATOR
  VIEWER
  // CLIENT = dono do veículo. Vê só os veículos vinculados via UserVehicleAccess.
  // Não acessa lista global, alertas de outros, geofences, etc.
  CLIENT
}

enum VehicleStatus {
  ACTIVE
  INACTIVE
  DEFAULTING
  BLOCKED
}

enum GeofenceType {
  POLYGON
  CIRCLE
}

enum DeviceModel {
  GT06N
  GT06
  ST310U
  ST340
  ST350
  J16
  J16_PRO
  CRX3
  CRX3_NANO
  CRX_PRO_4G
  TK103
  TK303
  FMB920
  FMB120
  COBAN_GPS103
  CONCOX_GT06N
  SINOTRACK_ST901
  SINOTRACK_ST905
  BLE_KTAG
  BLE_REDTAG
  BLE_AIRTAG_GENERIC
  OTHER
}

enum DeviceStatus {
  PENDING_INSTALL
  INSTALLED
  CONFIGURING
  ONLINE
  OFFLINE
  MAINTENANCE
  DEACTIVATED
}

enum ChipOperator {
  VIVO
  CLARO
  TIM
  OI
  MULTI_OPERATOR
}

enum ApnType {
  PUBLIC
  PRIVATE
}

enum ChipStatus {
  ACTIVE
  SUSPENDED
  EXPIRED
  BLOCKED
  CANCELLED
}

enum CommandType {
  SET_SERVER_IP
  SET_APN
  SET_TIMER
  SET_TIMEZONE
  BLOCK
  UNBLOCK
  RESTART
  GET_LOCATION
  GET_PARAMS
  GET_IMEI
  FACTORY_RESET
  CUSTOM
}

enum CommandStatus {
  PENDING
  SENT
  DELIVERED
  RESPONDED
  FAILED
}

enum AlertType {
  SPEED
  IGNITION_ON
  IGNITION_OFF
  SOS
  BATTERY_LOW
  OFFLINE
  GEOFENCE_IN
  GEOFENCE_OUT
}

enum AlertStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
}

enum AlertHistoryAction {
  CREATED
  ASSIGNED
  UNASSIGNED
  COMMENTED
  RESOLVED
  REOPENED
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  RESTORE
  LOGIN
  LOGOUT
  LOGIN_FAILED
  PASSWORD_RESET
  COMMAND_SENT
  OTHER
}

model Tenant {
  id           String    @id @default(uuid()) @db.Uuid
  name         String
  slug         String    @unique
  document     String?   @unique
  logoUrl      String?   @map("logo_url")
  primaryColor String    @default("#10b981") @map("primary_color")
  active       Boolean   @default(true)
  deletedAt    DateTime? @map("deleted_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  users         User[]
  vehicles      Vehicle[]
  associates    Associate[]
  alerts        Alert[]
  geofences     Geofence[]
  devices       Device[]
  chips         Chip[]
  bleSightings  BleSighting[]

  @@map("tenants")
}

model User {
  id                  String    @id @default(uuid()) @db.Uuid
  email               String    @unique
  password            String
  name                String
  role                Role      @default(VIEWER)
  active              Boolean   @default(true)
  traccarUserId       Int?      @map("traccar_user_id")
  tenantId            String    @map("tenant_id") @db.Uuid
  resetTokenHash      String?   @map("reset_token_hash")
  resetTokenExpiresAt DateTime? @map("reset_token_expires_at")
  deletedAt           DateTime? @map("deleted_at")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  tenant         Tenant              @relation(fields: [tenantId], references: [id])
  vehicleAccess  UserVehicleAccess[]

  @@index([tenantId, deletedAt])
  @@map("users")
}

/// Liga User (geralmente role=CLIENT) aos Vehicles que ele tem permissão de ver.
/// Modelagem N:N pra suportar família com múltiplos carros + cliente que vendeu
/// um veículo manter histórico só nos que ainda possui.
model UserVehicleAccess {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  vehicleId String   @map("vehicle_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@unique([userId, vehicleId])
  @@index([vehicleId])
  @@map("user_vehicle_access")
}

model Vehicle {
  id              String        @id @default(uuid()) @db.Uuid
  plate           String
  brand           String?
  model           String?
  year            Int?
  color           String?
  chassi          String?
  renavam         String?
  uniqueId        String        @unique @map("unique_id")
  traccarDeviceId Int?          @map("traccar_device_id")
  status          VehicleStatus @default(ACTIVE)
  tenantId        String        @map("tenant_id") @db.Uuid
  associateId     String?       @map("associate_id") @db.Uuid
  hinovaCode      String?       @map("hinova_code")
  lastSync        DateTime?     @map("last_sync")
  deletedAt       DateTime?     @map("deleted_at")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  tenant           Tenant              @relation(fields: [tenantId], references: [id])
  associate        Associate?          @relation(fields: [associateId], references: [id])
  alerts           Alert[]
  geofenceVehicles GeofenceVehicle[]
  device           Device?
  userAccess       UserVehicleAccess[]

  @@unique([plate, tenantId])
  @@map("vehicles")
}

model Associate {
  id         String    @id @default(uuid()) @db.Uuid
  name       String
  cpf        String
  rg         String?
  birthDate  DateTime? @map("birth_date")
  phone      String?
  email      String?
  tenantId   String    @map("tenant_id") @db.Uuid
  hinovaCode String?   @map("hinova_code")
  deletedAt  DateTime? @map("deleted_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  tenant   Tenant    @relation(fields: [tenantId], references: [id])
  vehicles Vehicle[]

  @@index([tenantId, deletedAt])
  @@map("associates")
}

model Alert {
  id           String      @id @default(uuid()) @db.Uuid
  type         AlertType
  message      String
  data         Json?
  read         Boolean     @default(false)
  status       AlertStatus @default(OPEN)
  assignedToId String?     @map("assigned_to_id") @db.Uuid
  assignedAt   DateTime?   @map("assigned_at")
  resolvedById String?     @map("resolved_by_id") @db.Uuid
  resolvedAt   DateTime?   @map("resolved_at")
  resolution   String?
  vehicleId    String      @map("vehicle_id") @db.Uuid
  tenantId     String      @map("tenant_id") @db.Uuid
  deletedAt    DateTime?   @map("deleted_at")
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")

  vehicle Vehicle        @relation(fields: [vehicleId], references: [id])
  tenant  Tenant         @relation(fields: [tenantId], references: [id])
  history AlertHistory[]

  @@index([tenantId, createdAt(sort: Desc)])
  @@index([tenantId, deletedAt])
  @@index([tenantId, status, createdAt(sort: Desc)])
  @@index([assignedToId, status])
  @@map("alerts")
}

model AlertHistory {
  id        String             @id @default(uuid()) @db.Uuid
  alertId   String             @map("alert_id") @db.Uuid
  userId    String?            @map("user_id") @db.Uuid
  userEmail String?            @map("user_email")
  action    AlertHistoryAction
  comment   String?
  metadata  Json?
  createdAt DateTime           @default(now()) @map("created_at")

  alert Alert @relation(fields: [alertId], references: [id], onDelete: Cascade)

  @@index([alertId, createdAt(sort: Desc)])
  @@map("alert_history")
}

model Geofence {
  id                String       @id @default(uuid()) @db.Uuid
  name              String
  description       String?
  type              GeofenceType
  coordinates       Json
  color             String       @default("#3b82f6")
  active            Boolean      @default(true)
  traccarGeofenceId Int?         @map("traccar_geofence_id")
  tenantId          String       @map("tenant_id") @db.Uuid
  deletedAt         DateTime?    @map("deleted_at")
  createdAt         DateTime     @default(now()) @map("created_at")
  updatedAt         DateTime     @updatedAt @map("updated_at")

  tenant           Tenant            @relation(fields: [tenantId], references: [id])
  geofenceVehicles GeofenceVehicle[]

  @@index([tenantId, deletedAt])
  @@map("geofences")
}

model GeofenceVehicle {
  id         String   @id @default(uuid()) @db.Uuid
  geofenceId String   @map("geofence_id") @db.Uuid
  vehicleId  String   @map("vehicle_id") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at")

  geofence Geofence @relation(fields: [geofenceId], references: [id], onDelete: Cascade)
  vehicle  Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@unique([geofenceId, vehicleId])
  @@map("geofence_vehicles")
}

model Device {
  id              String       @id @default(uuid()) @db.Uuid
  imei            String       @unique
  model           DeviceModel
  brand           String?
  firmwareVersion String?      @map("firmware_version")
  serialNumber    String?      @map("serial_number")
  traccarDeviceId Int?         @map("traccar_device_id")
  status          DeviceStatus @default(PENDING_INSTALL)
  chipId          String?      @unique @map("chip_id") @db.Uuid
  chip            Chip?        @relation(fields: [chipId], references: [id])
  vehicleId       String?      @unique @map("vehicle_id") @db.Uuid
  vehicle         Vehicle?     @relation(fields: [vehicleId], references: [id])
  tenantId        String       @map("tenant_id") @db.Uuid
  tenant          Tenant       @relation(fields: [tenantId], references: [id])
  installedAt     DateTime?    @map("installed_at")
  installedBy     String?      @map("installed_by")
  lastConnection  DateTime?    @map("last_connection")
  notes           String?
  deletedAt       DateTime?    @map("deleted_at")
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")

  smsCommands  SmsCommand[]
  bleSightings BleSighting[]

  @@index([tenantId, status])
  @@map("devices")
}

model BleSighting {
  id            String   @id @default(uuid()) @db.Uuid
  deviceId      String   @map("device_id") @db.Uuid
  device        Device   @relation(fields: [deviceId], references: [id])
  macAddress    String   @map("mac_address")
  rssi          Int
  hashedAdvKey  String?  @map("hashed_adv_key")
  counterByte   Int?     @map("counter_byte")
  scannerLat    Float?   @map("scanner_lat")
  scannerLng    Float?   @map("scanner_lng")
  scannerSource String?  @map("scanner_source")
  tenantId      String   @map("tenant_id") @db.Uuid
  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([tenantId, createdAt(sort: Desc)])
  @@index([deviceId, createdAt(sort: Desc)])
  @@map("ble_sightings")
}

model Chip {
  id          String       @id @default(uuid()) @db.Uuid
  iccid       String       @unique
  phoneNumber String?      @map("phone_number")
  operator    ChipOperator
  apn         String
  apnUser     String?      @map("apn_user")
  apnPassword String?      @map("apn_password")
  apnType     ApnType      @default(PRIVATE) @map("apn_type")
  dataPlanMb  Int          @default(50) @map("data_plan_mb")
  provider    String?
  status      ChipStatus   @default(ACTIVE)
  activatedAt DateTime?    @map("activated_at")
  expiresAt   DateTime?    @map("expires_at")
  device      Device?
  tenantId    String       @map("tenant_id") @db.Uuid
  tenant      Tenant       @relation(fields: [tenantId], references: [id])
  deletedAt   DateTime?    @map("deleted_at")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  @@index([tenantId, status])
  @@map("chips")
}

model SmsCommand {
  id          String        @id @default(uuid()) @db.Uuid
  deviceId    String        @map("device_id") @db.Uuid
  device      Device        @relation(fields: [deviceId], references: [id])
  command     String
  type        CommandType
  status      CommandStatus @default(PENDING)
  sentAt      DateTime?     @map("sent_at")
  response    String?
  respondedAt DateTime?     @map("responded_at")
  sentBy      String        @map("sent_by")
  tenantId    String        @map("tenant_id") @db.Uuid
  createdAt   DateTime      @default(now()) @map("created_at")

  @@index([deviceId, createdAt(sort: Desc)])
  @@map("sms_commands")
}

model AuditLog {
  id         String      @id @default(uuid()) @db.Uuid
  tenantId   String?     @map("tenant_id") @db.Uuid
  userId     String?     @map("user_id") @db.Uuid
  userEmail  String?     @map("user_email")
  action     AuditAction
  entity     String?
  entityId   String?     @map("entity_id")
  method     String
  path       String
  statusCode Int         @map("status_code")
  ip         String?
  userAgent  String?     @map("user_agent")
  metadata   Json?
  createdAt  DateTime    @default(now()) @map("created_at")

  @@index([tenantId, createdAt(sort: Desc)])
  @@index([userId, createdAt(sort: Desc)])
  @@index([entity, entityId])
  @@index([action, createdAt(sort: Desc)])
  @@map("audit_logs")
}
