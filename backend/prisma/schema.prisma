generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  SUPER_ADMIN
  ADMIN
  OPERATOR
  VIEWER
}

enum VehicleStatus {
  ACTIVE
  INACTIVE
  DEFAULTING
  BLOCKED
}

enum GeofenceType {
  POLYGON
  CIRCLE
}

enum DeviceModel {
  GT06N
  GT06
  ST310U
  ST340
  ST350
  J16
  J16_PRO
  CRX3
  CRX3_NANO
  CRX_PRO_4G
  TK103
  TK303
  FMB920
  FMB120
  COBAN_GPS103
  CONCOX_GT06N
  SINOTRACK_ST901
  SINOTRACK_ST905
  OTHER
}

enum DeviceStatus {
  PENDING_INSTALL
  INSTALLED
  CONFIGURING
  ONLINE
  OFFLINE
  MAINTENANCE
  DEACTIVATED
}

enum ChipOperator {
  VIVO
  CLARO
  TIM
  OI
  MULTI_OPERATOR
}

enum ApnType {
  PUBLIC
  PRIVATE
}

enum ChipStatus {
  ACTIVE
  SUSPENDED
  EXPIRED
  BLOCKED
  CANCELLED
}

enum CommandType {
  SET_SERVER_IP
  SET_APN
  SET_TIMER
  SET_TIMEZONE
  BLOCK
  UNBLOCK
  RESTART
  GET_LOCATION
  GET_PARAMS
  GET_IMEI
  FACTORY_RESET
  CUSTOM
}

enum CommandStatus {
  PENDING
  SENT
  DELIVERED
  RESPONDED
  FAILED
}

enum AlertType {
  SPEED
  IGNITION_ON
  IGNITION_OFF
  SOS
  BATTERY_LOW
  OFFLINE
  GEOFENCE_IN
  GEOFENCE_OUT
}

model Tenant {
  id           String   @id @default(uuid()) @db.Uuid
  name         String
  slug         String   @unique
  document     String?  @unique
  logoUrl      String?  @map("logo_url")
  primaryColor String   @default("#10b981") @map("primary_color")
  active       Boolean  @default(true)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  users      User[]
  vehicles   Vehicle[]
  associates Associate[]
  alerts     Alert[]
  geofences  Geofence[]
  devices    Device[]
  chips      Chip[]

  @@map("tenants")
}

model User {
  id                  String    @id @default(uuid()) @db.Uuid
  email               String    @unique
  password            String
  name                String
  role                Role      @default(VIEWER)
  active              Boolean   @default(true)
  traccarUserId       Int?      @map("traccar_user_id")
  tenantId            String    @map("tenant_id") @db.Uuid
  resetTokenHash      String?   @map("reset_token_hash")
  resetTokenExpiresAt DateTime? @map("reset_token_expires_at")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@map("users")
}

model Vehicle {
  id              String        @id @default(uuid()) @db.Uuid
  plate           String
  brand           String?
  model           String?
  year            Int?
  color           String?
  chassi          String?
  renavam         String?
  uniqueId        String        @unique @map("unique_id")
  traccarDeviceId Int?          @map("traccar_device_id")
  status          VehicleStatus @default(ACTIVE)
  tenantId        String        @map("tenant_id") @db.Uuid
  associateId     String?       @map("associate_id") @db.Uuid
  hinovaCode      String?       @map("hinova_code")
  lastSync        DateTime?     @map("last_sync")
  deletedAt       DateTime?     @map("deleted_at")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  tenant           Tenant             @relation(fields: [tenantId], references: [id])
  associate        Associate?         @relation(fields: [associateId], references: [id])
  alerts           Alert[]
  geofenceVehicles GeofenceVehicle[]
  device           Device?

  @@unique([plate, tenantId])
  @@map("vehicles")
}

model Associate {
  id         String    @id @default(uuid()) @db.Uuid
  name       String
  cpf        String
  rg         String?
  birthDate  DateTime? @map("birth_date")
  phone      String?
  email      String?
  tenantId   String    @map("tenant_id") @db.Uuid
  hinovaCode String?   @map("hinova_code")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  tenant   Tenant    @relation(fields: [tenantId], references: [id])
  vehicles Vehicle[]

  @@map("associates")
}

model Alert {
  id        String    @id @default(uuid()) @db.Uuid
  type      AlertType
  message   String
  data      Json?
  read      Boolean   @default(false)
  vehicleId String    @map("vehicle_id") @db.Uuid
  tenantId  String    @map("tenant_id") @db.Uuid
  createdAt DateTime  @default(now()) @map("created_at")

  vehicle Vehicle @relation(fields: [vehicleId], references: [id])
  tenant  Tenant  @relation(fields: [tenantId], references: [id])

  @@index([tenantId, createdAt(sort: Desc)])
  @@map("alerts")
}

model Geofence {
  id              String           @id @default(uuid()) @db.Uuid
  name            String
  description     String?
  type            GeofenceType
  coordinates     Json
  color           String           @default("#3b82f6")
  active          Boolean          @default(true)
  traccarGeofenceId Int?           @map("traccar_geofence_id")
  tenantId        String           @map("tenant_id") @db.Uuid
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")

  tenant          Tenant           @relation(fields: [tenantId], references: [id])
  geofenceVehicles GeofenceVehicle[]

  @@map("geofences")
}

model GeofenceVehicle {
  id          String   @id @default(uuid()) @db.Uuid
  geofenceId  String   @map("geofence_id") @db.Uuid
  vehicleId   String   @map("vehicle_id") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")

  geofence Geofence @relation(fields: [geofenceId], references: [id], onDelete: Cascade)
  vehicle  Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@unique([geofenceId, vehicleId])
  @@map("geofence_vehicles")
}

model Device {
  id              String       @id @default(uuid()) @db.Uuid
  imei            String       @unique
  model           DeviceModel
  brand           String?
  firmwareVersion String?      @map("firmware_version")
  serialNumber    String?      @map("serial_number")
  traccarDeviceId Int?         @map("traccar_device_id")
  status          DeviceStatus @default(PENDING_INSTALL)
  chipId          String?      @unique @map("chip_id") @db.Uuid
  chip            Chip?        @relation(fields: [chipId], references: [id])
  vehicleId       String?      @unique @map("vehicle_id") @db.Uuid
  vehicle         Vehicle?     @relation(fields: [vehicleId], references: [id])
  tenantId        String       @map("tenant_id") @db.Uuid
  tenant          Tenant       @relation(fields: [tenantId], references: [id])
  installedAt     DateTime?    @map("installed_at")
  installedBy     String?      @map("installed_by")
  lastConnection  DateTime?    @map("last_connection")
  notes           String?
  deletedAt       DateTime?    @map("deleted_at")
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")

  smsCommands SmsCommand[]

  @@index([tenantId, status])
  @@map("devices")
}

model Chip {
  id          String       @id @default(uuid()) @db.Uuid
  iccid       String       @unique
  phoneNumber String?      @map("phone_number")
  operator    ChipOperator
  apn         String
  apnUser     String?      @map("apn_user")
  apnPassword String?      @map("apn_password")
  apnType     ApnType      @default(PRIVATE) @map("apn_type")
  dataPlanMb  Int          @default(50) @map("data_plan_mb")
  provider    String?
  status      ChipStatus   @default(ACTIVE)
  activatedAt DateTime?    @map("activated_at")
  expiresAt   DateTime?    @map("expires_at")
  device      Device?
  tenantId    String       @map("tenant_id") @db.Uuid
  tenant      Tenant       @relation(fields: [tenantId], references: [id])
  deletedAt   DateTime?    @map("deleted_at")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  @@index([tenantId, status])
  @@map("chips")
}

model SmsCommand {
  id          String        @id @default(uuid()) @db.Uuid
  deviceId    String        @map("device_id") @db.Uuid
  device      Device        @relation(fields: [deviceId], references: [id])
  command     String
  type        CommandType
  status      CommandStatus @default(PENDING)
  sentAt      DateTime?     @map("sent_at")
  response    String?
  respondedAt DateTime?     @map("responded_at")
  sentBy      String        @map("sent_by")
  tenantId    String        @map("tenant_id") @db.Uuid
  createdAt   DateTime      @default(now()) @map("created_at")

  @@index([deviceId, createdAt(sort: Desc)])
  @@map("sms_commands")
}
